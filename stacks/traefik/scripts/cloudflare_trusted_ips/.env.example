# Edit this file on the host as .env. The Python core also accepts these values
# through the process environment when that fits your scheduler better.

TRAEFIK_CONFIG_PATH="/mnt/user/appdata/traefik/traefik.yml"
TRAEFIK_DYNAMIC_CONFIG_PATH="/mnt/user/appdata/traefik/dynamic.yml"
TRAEFIK_BACKUP_DIR="/mnt/user/appdata/traefik/backups"
TRAEFIK_RUNTIME_ENV_PATH="/mnt/user/appdata/komodo/repos/homelab/stacks/traefik/.env"
TEMP_REPO_BASE="/mnt/user/appdata/komodo/root/tmp"
HOMELAB_PRIVATE_REPO_URL="git@github.com:your-user/your-private-repo.git"
HOMELAB_PRIVATE_REPO_BRANCH="main"
HOMELAB_PRIVATE_ENV_ENC_PATH="stacks/traefik/.env.enc"
HOMELAB_PRIVATE_ENV_EXAMPLE_PATH="stacks/traefik/.env.example"
HOMELAB_PRIVATE_COMMIT_MESSAGE="[Traefik] Refresh Cloudflare trusted IPs"
GIT_AUTHOR_NAME="Cloudflare Trusted IP Sync"
GIT_AUTHOR_EMAIL="cloudflare-trusted-ips@example.invalid"
PERIPHERY_CONTAINER="komodo-periphery"
PERIPHERY_SOPS_AGE_KEY_FILE="/root/.config/sops/age/keys.txt"
CLOUDFLARE_IPV4_URL="https://www.cloudflare.com/ips-v4"
CLOUDFLARE_IPV6_URL="https://www.cloudflare.com/ips-v6"
