# This file is the tracked example environment file for this stack. Sensitive values are intentionally blank.
ADGUARD_HOME_SYNC_EXTERNAL_URL=adghsync.example.com
# Use the Docker-network URL here so Traefik reaches the service via smoonet.
ADGUARD_HOME_SYNC_INTERNAL_URL=http://adguard-home-sync:8080
ADGUARD_HOME_SYNC_UNRAID_WEBGUI_URL=http://192.0.2.99:9105
ADGUARD_HOME_SYNC_SERVICE=adhsync
SERVICE=adguard-storage-host
SPECIAL_HEADER_NAME=X-Homelab-Access-Bypass
SPECIAL_HEADER_SECRET=""
TRAEFIK_EXTERNAL_URL=adguard2.example.com
# Use AdGuard's Docker-network URL here so Traefik reaches the service via smoonet.
TRAEFIK_INTERNAL_URL=http://adguard-home-unbound
UNRAID_WEBGUI_URL=http://192.0.2.3
