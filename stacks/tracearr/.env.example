# This file is the tracked example environment file for this stack. Sensitive values are intentionally blank.
SERVICE=tracearr
SPECIAL_HEADER_NAME=X-Homelab-Access-Bypass
SPECIAL_HEADER_SECRET=""
TRAEFIK_EXTERNAL_URL=tracearr.example.com
TRAEFIK_INTERNAL_URL=http://192.0.2.99:3004
## Tracearr
TRACEARR_LOG_LEVEL=info
TRACEARR_MEM_LIMIT=3g
TRACEARR_PG_MAX_MEMORY=2GB
TRACEARR_PORT=3004
TRACEARR_SHM_SIZE=512mb
TRACEARR_TZ=Europe/Berlin
